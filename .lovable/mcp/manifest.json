{
  "version": 1,
  "sdk_version": "0.22.0",
  "path": "/mcp",
  "auth": {
    "type": "oauth",
    "issuer": "https://gtrrkecpuqswlxekynml.supabase.co/auth/v1",
    "accepted_audiences": [
      "authenticated"
    ]
  },
  "mcp": {
    "server": {
      "name": "nova-app-store-mcp",
      "version": "0.1.0",
      "title": "Nova App Store"
    },
    "tools": [
      {
        "name": "search_apps",
        "title": "Search apps",
        "description": "Search the Nova App Store catalog of published, live apps by name, tagline, short description, or tag. Optionally filter by category.",
        "annotations": {
          "readOnlyHint": true,
          "idempotentHint": true,
          "openWorldHint": false
        },
        "inputSchema": {
          "$schema": "http://json-schema.org/draft-07/schema#",
          "type": "object",
          "properties": {
            "query": {
              "description": "Free-text search term.",
              "type": "string",
              "minLength": 1,
              "maxLength": 120
            },
            "category": {
              "description": "Filter by app category.",
              "type": "string",
              "enum": [
                "app",
                "game",
                "ai_video"
              ]
            },
            "limit": {
              "description": "Max results (default 20).",
              "type": "integer",
              "minimum": 1,
              "maximum": 50
            }
          }
        },
        "outputSchema": null
      },
      {
        "name": "get_app",
        "title": "Get app details",
        "description": "Fetch full details for a single Nova App Store listing by slug, including description, developer info, permissions, and version.",
        "annotations": {
          "readOnlyHint": true,
          "idempotentHint": true,
          "openWorldHint": false
        },
        "inputSchema": {
          "$schema": "http://json-schema.org/draft-07/schema#",
          "type": "object",
          "properties": {
            "slug": {
              "type": "string",
              "minLength": 1,
              "maxLength": 120,
              "description": "The app's URL slug (e.g. 'my-cool-app')."
            }
          },
          "required": [
            "slug"
          ]
        },
        "outputSchema": null
      },
      {
        "name": "list_my_library",
        "title": "List my installed apps",
        "description": "List the apps the signed-in Nova user has installed, including the installed version and install date.",
        "annotations": {
          "readOnlyHint": true,
          "idempotentHint": true,
          "openWorldHint": false
        },
        "inputSchema": {
          "$schema": "http://json-schema.org/draft-07/schema#",
          "type": "object",
          "properties": {}
        },
        "outputSchema": null
      },
      {
        "name": "list_my_developer_apps",
        "title": "List my developer apps",
        "description": "List apps the signed-in user has published or drafted as a developer on Nova App Store, including status and install count.",
        "annotations": {
          "readOnlyHint": true,
          "idempotentHint": true,
          "openWorldHint": false
        },
        "inputSchema": {
          "$schema": "http://json-schema.org/draft-07/schema#",
          "type": "object",
          "properties": {}
        },
        "outputSchema": null
      },
      {
        "name": "whoami",
        "title": "Who am I",
        "description": "Return the signed-in Nova App Store user's profile (display name, avatar, premium status).",
        "annotations": {
          "readOnlyHint": true,
          "idempotentHint": true,
          "openWorldHint": false
        },
        "inputSchema": {
          "$schema": "http://json-schema.org/draft-07/schema#",
          "type": "object",
          "properties": {}
        },
        "outputSchema": null
      }
    ]
  }
}
